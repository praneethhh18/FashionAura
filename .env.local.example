# Copy this file to .env.local and fill values for local development
# MongoDB connection
MONGODB_URI="mongodb+srv://<user>:<password>@cluster0.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB="fashion-aura"

# Other environment variables (example)
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# =============================================================================
# IncidentIQ reporter destinations
# =============================================================================
# The reporter (src/lib/incidentiq-reporter.ts) fans every error out to any
# of the destinations below that have credentials set. Configure as many or
# as few as you want - missing creds are skipped silently.

# 1) IncidentIQ direct webhook (always recommended)
INCIDENTIQ_WEBHOOK_URL="http://localhost:8000/api/v1/webhook/generic"
# In production:
#   INCIDENTIQ_WEBHOOK_URL="https://your-incidentiq.example.com/api/v1/webhook/generic"

# 2) Datadog Logs HTTP intake (no agent needed)
# Sign up: https://www.datadoghq.com/free-datadog-trial/
# Get key: Organization Settings -> API Keys -> + New Key
# DATADOG_API_KEY=
# DATADOG_SITE=datadoghq.com    # or datadoghq.eu, us3.datadoghq.com, etc.

# 3) Grafana Cloud Loki HTTP push (no agent needed)
# Sign up: https://grafana.com/auth/sign-up/create-user
# Find Loki: Connections -> Data Sources -> Loki (the URL field)
# Auth:      Security -> Access Policies -> scope=logs:write -> Add token
# GRAFANA_LOKI_URL="https://logs-prod-006.grafana.net"
# GRAFANA_LOKI_AUTH="<userId>:<apiToken>"

# 4) New Relic Logs HTTP API (no agent needed)
# Sign up: https://newrelic.com/signup
# Get key: API keys -> + Create a key -> type "INGEST - LICENSE" (NRII-...)
# NEW_RELIC_LICENSE_KEY=
# NEW_RELIC_EU=1                # set only if your NR region is EU
